{
  "name": "stockanalyzer",
  "version": "1.0.0",
  "description": "基于 Electron + Vite + Vue3 + TypeScript 的股票分析桌面应用",
  "main": "dist-electron/electron/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "npm run build:electron && vite",
    "build": "npm run build:electron && vite build",
    "build:electron": "tsc -p tsconfig.node.json",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "lint:fix": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "electron-log": "^5.1.1",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.2.1",
    "@commitlint/config-conventional": "^19.1.0",
    "@types/node": "^20.11.28",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/eslint-config-typescript": "^12.0.0",
    "electron": "^28.2.10",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.23.0",
    "prettier": "^3.2.5",
    "sass": "^1.72.0",
    "typescript": "^5.4.2",
    "vite": "^5.1.7",
    "vue-tsc": "^2.0.6"
  },
  "build": {
    "appId": "com.stockanalyzer.app",
    "productName": "StockAnalyzer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraMetadata": {
      "main": "dist-electron/electron/index.js"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}