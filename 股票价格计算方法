   private double calcHoldingPrice(TradeRecord preTradeRecord, TradeRecord tradeRecord) {
        // 如果当前持仓为0了，那么holdingPrice如何理解？
        if(tradeRecord.getHoldingCount() == 0) {
            return 0;
        }
        // 对于分红或者是分红扣税，计算方法不一样
        if(tradeRecord.getTradeType().equals(TRADE_TYPE_DIVIDEND)
                || tradeRecord.getTradeType().equals(TRADE_TYPE_BONUS_TAX)) { //分红或者分红扣税
            return preTradeRecord.getHoldingPrice() - tradeRecord.getTradePrice();
        }
        // 需要区分交易所
        String exchange = ExchangeUtils.getExchangeByStockCode(tradeRecord.getStockCode());
        double tradeFee = tradeRecord.getTradeCount() * tradeRecord.getTradePrice() * TRADE_FEE_RATE;
        tradeFee = tradeFee < 5 ? 5 : tradeFee;
        double huaTaiFee = tradeRecord.getTradeCount() * tradeRecord.getTradePrice() * HUATAI_OTHER_FEE_RATE;
        if(exchange.equals(EXCHANGE_SHENZHEN)) {
            // 深交所
            // 如果是买入的话，只需要交易手续费（最低5元）；
            // 卖出的话，需要交易手续费（最低5元）+千分之一的印花税
            if(tradeRecord.getTradeType().equals(TRADE_TYPE_BUY)) {
                return (double)Math.round((preTradeRecord.getHoldingCount() * preTradeRecord.getHoldingPrice()
                        + tradeRecord.getTradeCount() * tradeRecord.getTradePrice() + tradeFee + huaTaiFee) * 1000
                        / (preTradeRecord.getHoldingCount() + tradeRecord.getTradeCount())) / 1000;
            } else {
                double tax = -tradeRecord.getTradeCount() * tradeRecord.getTradePrice() * SHENZHEN_STAMP_TAX_RATE;
                return (double)Math.round((preTradeRecord.getHoldingCount() * preTradeRecord.getHoldingPrice()
                        + tradeRecord.getTradeCount() * tradeRecord.getTradePrice() + tradeFee + tax + huaTaiFee) * 1000
                        / (preTradeRecord.getHoldingCount() + tradeRecord.getTradeCount())) / 1000;
            }
        } else if(exchange.equals(EXCHANGE_SHANGHAI)) {
            // 上交所
            // 如果是买入的话，需要交易手续费（最低5元）；
            // 卖出的话，需要交易手续费（最低5元）+千分之一的印花税
            //
            if(tradeRecord.getTradeType().equals(TRADE_TYPE_BUY)) {
                return (double)Math.round((preTradeRecord.getHoldingCount() * preTradeRecord.getHoldingPrice()
                        + tradeRecord.getTradeCount() * tradeRecord.getTradePrice() + tradeFee) * 1000
                        / (preTradeRecord.getHoldingCount() + tradeRecord.getTradeCount())) / 1000;
            } else {
                double tax = -tradeRecord.getTradeCount() * tradeRecord.getTradePrice() * SHANGHAI_STAMP_TAX_RATE;
                return (double)Math.round((preTradeRecord.getHoldingCount() * preTradeRecord.getHoldingPrice()
                        + tradeRecord.getTradeCount() * tradeRecord.getTradePrice() + tradeFee + tax + huaTaiFee) * 1000
                        / (preTradeRecord.getHoldingCount() + tradeRecord.getTradeCount())) / 1000;
            }
        } else { // 北交所暂时不考虑
            return (double)Math.round((preTradeRecord.getHoldingCount() * preTradeRecord.getHoldingPrice()
                    + tradeRecord.getTradeCount() * tradeRecord.getTradePrice()) * 1000
                    / (preTradeRecord.getHoldingCount() + tradeRecord.getTradeCount())) / 1000;
        }
    }